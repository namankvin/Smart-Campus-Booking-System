{
  "name": "smart-campus-booking",
  "version": "1.0.0",
  "description": "Smart Campus Booking System",
  "main": "server/server.js",
  "scripts": {
    "start": "node server/server.js",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "nodemon server/server.js",
    "client": "npm start --prefix client",
    "install-client": "npm install --prefix client",
    "build": "npm run build --prefix client",
    "heroku-postbuild": "npm run build",
    "test": "npm run test:server",
    "test:server": "jest --runInBand --detectOpenHandles --setupFilesAfterEnv ./server/tests/setup.js --testMatch '**/server/tests/**/*.test.js'",
    "test:client": "CI=true npm test --prefix client -- --watchAll=false",
    "test:all": "npm run test:server && npm run test:client"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^6.10.0",
    "google-auth-library": "^9.15.1",
    "helmet": "^7.0.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^7.5.0",
    "morgan": "^1.10.0",
    "nodemailer": "^6.9.5",
    "passport": "^0.6.0",
    "passport-google-oauth20": "^2.0.0",
    "socket.io": "^4.7.2"
  },
  "devDependencies": {
    "concurrently": "^8.2.0",
    "jest": "^30.3.0",
    "mongodb-memory-server": "^11.0.1",
    "nodemon": "^3.0.1",
    "supertest": "^7.2.2"
  }
}
