MONGO_URI=mongodb://localhost:27017/smart-campus-booking
JWT_SECRET=replace-with-strong-secret
JWT_EXPIRES_IN=12h
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:3000

# Google OAuth (server-side token verification)
GOOGLE_CLIENT_ID=your-google-web-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=optional-for-this-app

# Institutional domain policy
# Leave unset to allow any institutional account ending with .nitw.ac.in
# If set, it must match exactly after @ (example: student.nitw.ac.in)
# INSTITUTIONAL_EMAIL_DOMAIN=student.nitw.ac.in

EMAIL_USER=
EMAIL_PASS=
